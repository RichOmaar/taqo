// Nexa data model. Field names are camelCase in Prisma and mapped to snake_case
// columns; enum values mirror the shared contracts in @nexa/types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RestaurantPlan {
  free
  paid
}

enum WaitlistStatus {
  waiting
  notified
  seated
  no_show
  cancelled
}

enum ProgramStatus {
  draft
  active
  paused
}

enum AccrualMode {
  visits
  points
  both
}

enum TierMetric {
  visits
  points
}

enum TierPeriod {
  lifetime
  rolling
}

enum DowngradePolicy {
  never
  on_period_exit
}

enum MembershipStatus {
  active
  cancelled
}

enum LedgerKind {
  accrual
  redemption
  expiry
  adjustment
}

enum RedemptionStatus {
  issued
  redeemed
  expired
  cancelled
}

enum SurveyPurpose {
  intake
  feedback
}

enum SurveyStatus {
  draft
  active
  closed
}

enum QuestionType {
  short_text
  long_text
  number
  phone
  email
  single_choice
  multi_choice
  rating
  nps
  boolean
  date
}

enum NotificationChannel {
  web_push
  sms
  whatsapp
}

enum NotificationEventType {
  registered
  turn_near
  table_ready
}

enum NotificationStatus {
  sent
  failed
}

model Restaurant {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  code              String         @unique
  qrToken           String         @unique @map("qr_token")
  etaBaseMinutes    Int            @map("eta_base_minutes")
  expirationMinutes Int            @map("expiration_minutes")
  plan              RestaurantPlan @default(free)
  /// IANA zone used to bucket metrics by local day; "today" is meaningless without it.
  timezone          String         @default("America/Mexico_City")
  createdAt         DateTime       @default(now()) @map("created_at")

  queues  Queue[]
  entries WaitlistEntry[]
  reviews ServiceReview[]
  staff   User[]

  @@map("restaurants")
}

model Queue {
  id           String  @id @default(uuid()) @db.Uuid
  restaurantId String  @map("restaurant_id") @db.Uuid
  name         String
  priority     Int     @default(0)
  isActive     Boolean @default(true) @map("is_active")

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  entries    WaitlistEntry[]

  @@index([restaurantId])
  @@map("queues")
}

model WaitlistEntry {
  id           String         @id @default(uuid()) @db.Uuid
  queueId      String         @map("queue_id") @db.Uuid
  restaurantId String         @map("restaurant_id") @db.Uuid
  userId       String?        @map("user_id")
  displayName  String         @map("display_name")
  partySize    Int            @map("party_size")
  phone        String?
  status       WaitlistStatus @default(waiting)
  position     Int
  etaMinutes   Int?           @map("eta_minutes")
  etaIsManual  Boolean        @default(false) @map("eta_is_manual")
  formData     Json           @default("{}") @map("form_data")
  joinedAt     DateTime       @default(now()) @map("joined_at")
  notifiedAt   DateTime?      @map("notified_at")
  seatedAt     DateTime?      @map("seated_at")

  queue         Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  notifications Notification[]
  review        ServiceReview?

  @@index([queueId, status])
  @@index([restaurantId])
  @@map("waitlist_entries")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  emailVerified Boolean  @default(false)
  image         String?
  // diner (default) | hostess | admin
  role          String?  @default("diner")
  // Staff (hostess/admin) belong to exactly one restaurant and may only act on
  // it. Null for diners, who are not scoped to any restaurant.
  restaurantId  String?  @map("restaurant_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt

  restaurant  Restaurant?     @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  entries     WaitlistEntry[]
  sessions    Session[]
  accounts    Account[]
  memberships Membership[]

  @@index([restaurantId])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  entryId   String   @map("entry_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entryId])
  @@map("push_subscriptions")
}

// Surveys — configurable forms and the responses they collect.

model Survey {
  id          String        @id @default(uuid()) @db.Uuid
  /// Opaque owner reference, as in memberships: this context knows nothing
  /// about restaurants, which keeps it reusable for other Nexa verticals.
  ownerRef    String        @map("owner_ref")
  purpose     SurveyPurpose
  title       String
  description String?
  status      SurveyStatus  @default(draft)
  /// Bumped only when an edit changes what a response means, so a stored
  /// answer stays interpretable against the definition it was given to.
  version     Int           @default(1)
  createdAt   DateTime      @default(now()) @map("created_at")

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([ownerRef, purpose])
  @@map("surveys")
}

model SurveyQuestion {
  id       String       @id @default(uuid()) @db.Uuid
  surveyId String       @map("survey_id") @db.Uuid
  type     QuestionType
  label    String
  helpText String?      @map("help_text")
  required Boolean      @default(false)
  /// Ascending from 0.
  position Int
  /// Type-specific settings: options, scale, bounds.
  config   Json         @default("{}")

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@unique([surveyId, position])
  @@map("survey_questions")
}

model SurveyResponse {
  id            String   @id @default(uuid()) @db.Uuid
  surveyId      String   @map("survey_id") @db.Uuid
  /// The definition version answered against.
  surveyVersion Int      @map("survey_version")
  /// What the response is about — a waitlist entry, for a feedback survey.
  subjectRef    String?  @map("subject_ref")
  submittedAt   DateTime @default(now()) @map("submitted_at")

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@unique([surveyId, subjectRef])
  @@index([surveyId, submittedAt])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         String @id @default(uuid()) @db.Uuid
  responseId String @map("response_id") @db.Uuid
  questionId String @map("question_id") @db.Uuid
  /// Shape follows the question type; validated before it is written.
  value      Json

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@map("survey_answers")
}

// Memberships — loyalty programs, their members, and an append-only ledger.

model MembershipProgram {
  id       String        @id @default(uuid()) @db.Uuid
  /// Opaque owner reference, deliberately not a Restaurant FK: it keeps this
  /// context independent and leaves room for a Nexa-wide program later.
  ownerRef String        @map("owner_ref")
  name     String
  status   ProgramStatus @default(draft)

  accrualMode     AccrualMode     @default(visits) @map("accrual_mode")
  pointsPerVisit  Int             @default(10) @map("points_per_visit")
  tierMetric      TierMetric      @default(visits) @map("tier_metric")
  tierPeriod      TierPeriod      @default(lifetime) @map("tier_period")
  /// Null when the period is lifetime.
  tierWindowDays  Int?            @map("tier_window_days")
  downgradePolicy DowngradePolicy @default(never) @map("downgrade_policy")

  /// Bumped when the tier scheme changes, so an awarded tier stays readable
  /// against the rules in force when it was granted.
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  tiers       MembershipTier[]
  memberships Membership[]
  rewards     Reward[]

  @@index([ownerRef])
  @@map("membership_programs")
}

model MembershipTier {
  id        String   @id @default(uuid()) @db.Uuid
  programId String   @map("program_id") @db.Uuid
  name      String
  threshold Int
  benefits  String[]
  /// Ascending from 0 for the entry level.
  position  Int

  program MembershipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, position])
  @@map("membership_tiers")
}

model Membership {
  id               String           @id @default(uuid()) @db.Uuid
  programId        String           @map("program_id") @db.Uuid
  /// Membership requires a registered diner; guests have no durable identity.
  userId           String           @map("user_id")
  status           MembershipStatus @default(active)
  /// Highest tier position ever awarded, so a "never demote" policy can honour
  /// a level the ledger alone no longer supports.
  heldTierPosition Int?             @map("held_tier_position")
  enrolledAt       DateTime         @default(now()) @map("enrolled_at")

  program     MembershipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger      LedgerEntry[]
  redemptions Redemption[]

  @@unique([programId, userId])
  @@map("memberships")
}

model LedgerEntry {
  id           String     @id @default(uuid()) @db.Uuid
  membershipId String     @map("membership_id") @db.Uuid
  kind         LedgerKind
  /// Signed: positive on accrual, negative on redemption or expiry.
  points       Int        @default(0)
  visits       Int        @default(0)
  /// What caused the movement. Unique per membership, which is what makes
  /// re-processing the same seating idempotent.
  sourceRef    String     @map("source_ref")
  note         String?
  occurredAt   DateTime   @default(now()) @map("occurred_at")

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, sourceRef])
  @@index([membershipId, occurredAt])
  @@map("membership_ledger_entries")
}

model Reward {
  id              String  @id @default(uuid()) @db.Uuid
  programId       String  @map("program_id") @db.Uuid
  name            String
  description     String?
  costPoints      Int     @default(0) @map("cost_points")
  /// Lowest tier position allowed to redeem; null for any member.
  minTierPosition Int?    @map("min_tier_position")
  /// Redemptions allowed per member; null for unlimited.
  limitPerMember  Int?    @map("limit_per_member")
  isActive        Boolean @default(true) @map("is_active")

  program     MembershipProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@map("membership_rewards")
}

model Redemption {
  id           String           @id @default(uuid()) @db.Uuid
  rewardId     String           @map("reward_id") @db.Uuid
  membershipId String           @map("membership_id") @db.Uuid
  /// Shown to the diner and read back by the hostess in the restaurant.
  code         String           @unique
  status       RedemptionStatus @default(issued)
  issuedAt     DateTime         @default(now()) @map("issued_at")
  redeemedAt   DateTime?        @map("redeemed_at")
  expiresAt    DateTime?        @map("expires_at")

  reward     Reward     @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
  @@map("membership_redemptions")
}

model Notification {
  id        String                @id @default(uuid()) @db.Uuid
  entryId   String                @map("entry_id") @db.Uuid
  channel   NotificationChannel
  eventType NotificationEventType @map("event_type")
  status    NotificationStatus
  sentAt    DateTime              @default(now()) @map("sent_at")

  entry WaitlistEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("notifications")
}

model ServiceReview {
  id           String   @id @default(uuid()) @db.Uuid
  entryId      String   @unique @map("entry_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  rating       Int
  feedback     String?
  createdAt    DateTime @default(now()) @map("created_at")

  entry      WaitlistEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("service_reviews")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
