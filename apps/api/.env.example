# API
NODE_ENV=development
API_PORT=4000

# Database (Prisma) — matches docker-compose.yml
DATABASE_URL=postgresql://nexa:nexa@localhost:5433/nexa

# Auth (BetterAuth)
BETTER_AUTH_SECRET=replace-with-a-32+-char-random-secret
BETTER_AUTH_URL=http://localhost:4000

# Web push (VAPID) — generate with: pnpm --filter @nexa/api exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
